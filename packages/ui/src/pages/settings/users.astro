---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import EmptyState from '../../components/common/EmptyState.astro';
import { api } from '../../lib/api';

const cookie = Astro.request.headers.get('cookie') ?? '';
let users: any[] = [];
let authConfig = { mode: 'password', saml_enabled: false, saml_login_url: null } as {
  mode: string;
  saml_enabled: boolean;
  saml_login_url: string | null;
};

try {
  const [usersRes, configRes] = await Promise.all([
    api<{ data: any[] }>('/users', { cookie }),
    api<{ data: typeof authConfig }>('/auth/config'),
  ]);
  users = usersRes.data;
  authConfig = configRes.data;
} catch {}

const currentTab = 'users';
const showCreateUser = authConfig.mode !== 'saml';
---

<DashboardLayout title="Users">
  <div class="mb-6">
    <h2 class="text-lg font-semibold text-foreground">Settings</h2>
  </div>

  <!-- Settings Tabs -->
  <div class="border-b border-border mb-6">
    <nav class="flex gap-0">
      <a href="/settings/api-keys" class={`px-4 py-2 text-xs font-medium border-b-2 transition-colors ${currentTab === 'api-keys' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground hover:border-border'}`}>
        API Keys
      </a>
      <a href="/settings/webhooks" class={`px-4 py-2 text-xs font-medium border-b-2 transition-colors ${currentTab === 'webhooks' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground hover:border-border'}`}>
        Webhooks
      </a>
      <a href="/settings/users" class={`px-4 py-2 text-xs font-medium border-b-2 transition-colors ${currentTab === 'users' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground hover:border-border'}`}>
        Users
      </a>
    </nav>
  </div>

  {users.length === 0 ? (
    <EmptyState title="No users" description="Users will appear here once created." />
  ) : (
    <div class="rounded-lg border border-border bg-card">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border text-xs font-medium uppercase tracking-wider text-muted-foreground">
            <th class="px-4 py-3 text-left">User</th>
            <th class="px-4 py-3 text-left">Email</th>
            <th class="px-4 py-3 text-left">Auth</th>
            <th class="px-4 py-3 text-right">Role</th>
          </tr>
        </thead>
        <tbody>
          {users.map((user: any) => (
            <tr class="border-b border-border/50 hover:bg-accent/50 transition-colors">
              <td class="px-4 py-3">
                <span class="text-sm font-medium text-foreground">{user.name}</span>
              </td>
              <td class="px-4 py-3">
                <span class="text-xs text-muted-foreground">{user.email}</span>
              </td>
              <td class="px-4 py-3">
                <span class:list={[
                  'inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium',
                  user.auth_method === 'saml'
                    ? 'bg-blue-500/10 text-blue-400'
                    : 'bg-muted text-muted-foreground',
                ]}>
                  {user.auth_method === 'saml' ? 'SSO' : 'Password'}
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <span class:list={[
                  'inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium',
                  user.role === 'admin'
                    ? 'bg-primary/10 text-primary'
                    : 'bg-muted text-muted-foreground',
                ]}>
                  {user.role}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</DashboardLayout>
