  <table>
    <thead>
      <tr><th>Method</th><th>Path</th><th>Auth</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>GET</code></td><td><code>/projects/:pid/webhooks</code></td><td>Session</td><td>List webhooks</td></tr>
      <tr><td><code>POST</code></td><td><code>/projects/:pid/webhooks</code></td><td>Admin</td><td>Create webhook</td></tr>
      <tr><td><code>PATCH</code></td><td><code>/projects/:pid/webhooks/:id</code></td><td>Admin</td><td>Update webhook</td></tr>
      <tr><td><code>DELETE</code></td><td><code>/projects/:pid/webhooks/:id</code></td><td>Admin</td><td>Delete webhook</td></tr>
