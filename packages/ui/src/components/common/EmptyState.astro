---
interface Props {
  title: string;
  description?: string;
  action?: { label: string; href: string };
}

const { title, description, action } = Astro.props;
---

<div class="text-center py-16">
  <h3 class="text-sm font-medium text-foreground">{title}</h3>
  {description && <p class="mt-1 text-xs text-muted-foreground">{description}</p>}
  {action && (
    <div class="mt-4">
      <a
        href={action.href}
        class="inline-flex items-center px-3 py-1.5 bg-primary text-primary-foreground text-xs font-medium rounded-md hover:bg-primary/90 transition-colors"
      >
        {action.label}
      </a>
    </div>
  )}
</div>
