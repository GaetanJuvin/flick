{
  "name": "@flick/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.2",
    "@flick/shared": "workspace:*",
    "@node-saml/node-saml": "^5.1.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "murmurhash-js": "^1.0.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
