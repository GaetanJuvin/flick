# Database
DATABASE_URL=postgresql://flick:flick_dev@localhost:5432/flick

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Auth
SESSION_SECRET=change-me-in-production

# Auth Mode: password | saml | both
AUTH_MODE=password

# SAML SSO (required when AUTH_MODE is saml or both)
# SAML_ENTRY_POINT=https://your-idp.example.com/sso/saml
# SAML_ISSUER=flick
# SAML_IDP_CERT=MIICizCCAfSgAwIBAgI...
# SAML_CALLBACK_URL=http://localhost:3456/api/v1/auth/saml/callback
# SAML_ATTR_EMAIL=email
# SAML_ATTR_NAME=name

# Logging
LOG_LEVEL=debug
